# Runtime
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Protect every /api/* route. Required when ENVIRONMENT=production.
API_AUTH_TOKEN=replace-with-a-long-random-token

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2

# Supabase — service role is required in production because public RLS access is revoked.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Browser access is disabled by default. Comma-separated exact origins only.
CORS_ALLOWED_ORIGINS=
TRUSTED_HOSTS=localhost,127.0.0.1,your-api.example.com

# Ingestion safety
INGEST_ALLOWED_HOSTS=cdn.discordapp.com,media.discordapp.net
INGEST_MAX_ATTACHMENTS=5
INGEST_MAX_FILE_BYTES=20971520
INGEST_MAX_TOTAL_CHARS=2000000
INGEST_DOWNLOAD_TIMEOUT_SECONDS=30
INGEST_MAX_PDF_PAGES=1000

# Optional OCR and reranking providers
MISTRAL_API_KEY=
COHERE_API_KEY=

# RAG behavior
HISTORY_ENABLED=true
HISTORY_RETENTION_DAYS=90
SCORE_THRESHOLD=0.30
MAX_CHUNKS=10

# Optional observability. PII remains disabled in code.
SENTRY_DSN=
RELEASE_VERSION=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
